<header class="pointer-events-none relative z-50 flex flex-none flex-col">
  <div class="top-0 z-10 h-16 pt-6">
    <%= render Container.new do %>
      <div class="relative flex gap-4">
        <div class="flex flex-1">
          <% unless is_home_page? %>
            <div class="h-16 w-32 rounded-lg bg-white/90 p-2 shadow-lg ring-1 shadow-zinc-800/5 ring-zinc-900/5 backdrop-blur-sm">
              <a href="/" aria-label="Home" class="pointer-events-auto">
                <img src="<%= relative_url '/images/redwood_power_logo_transparent.png' %>" alt="Redwood Power Fund" class="h-12 w-28 rounded-sm object-contain" />
              </a>
            </div>
          <% end %>
        </div>
        <div class="flex flex-1 justify-end md:justify-center">
          <!-- Mobile Navigation -->
          <div class="pointer-events-auto md:hidden" data-controller="toggle">
            <button class="group flex items-center rounded-full bg-white/90 px-4 py-2 text-sm font-medium text-zinc-800 shadow-lg ring-1 shadow-zinc-800/5 ring-zinc-900/5 backdrop-blur-sm" data-action="click->toggle#toggleMenu" data-toggle-target="button">
              Menu
              <svg viewBox="0 0 8 6" aria-hidden="true" class="ml-3 h-auto w-2 stroke-zinc-500 group-hover:stroke-zinc-700">
                <path d="M1.75 1.75 4 4.25l2.25-2.5" fill="none" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            </button>
          </div>

          <!-- Desktop Navigation -->
          <nav class="pointer-events-auto hidden md:block">
            <ul class="flex rounded-full bg-white/90 px-3 text-sm font-medium text-zinc-800 shadow-lg ring-1 shadow-zinc-800/5 ring-zinc-900/5 backdrop-blur-sm">
              <% navigation_items.each do |item| %>
                <li>
                  <a href="<%= item[:href] %>" class="relative block px-3 py-2 transition hover:text-forest-600"><%= item[:name] %></a>
                </li>
              <% end %>
            </ul>
          </nav>
        </div>
        <div class="flex justify-end md:flex-1">
        </div>
      </div>
    <% end %>
  </div>

  <!-- Home Page Avatar -->
  <% if is_home_page? %>
    <div class="order-last mt-[calc(theme(spacing.16)-theme(spacing.3))]">
      <%= render Container.new(outer_class: "top-0 order-last -mb-3 pt-3") do %>
        <div class="top-3 w-full">
          <div class="relative">
            <div class="h-24 w-24 rounded-lg bg-white/90 p-1 shadow-lg ring-1 shadow-zinc-800/5 ring-zinc-900/5 backdrop-blur-sm absolute top-3 left-0 origin-left transition-opacity opacity-0">
              <img src="<%= relative_url '/images/redwood_power_logo_transparent.png' %>" alt="Redwood Power Fund" class="h-22 w-22 rounded-sm object-contain" />
            </div>
            <a href="/" aria-label="Home" class="pointer-events-auto block h-36 w-36 origin-left">
              <img src="<%= relative_url '/images/redwood_power_logo_transparent.png' %>" alt="Redwood Power Fund" class="h-36 w-36 rounded-lg object-contain" />
            </a>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</header>

<!-- Content offset for homepage avatar spacing -->
<% if is_home_page? %>
  <div class="flex-none h-16"></div>
<% end %>

<!-- Mobile Menu -->
<div class="mobile-menu fixed inset-x-4 top-8 z-50 origin-top rounded-3xl bg-white p-8 ring-1 ring-zinc-900/5 transition duration-150 hidden" role="dialog" aria-modal="true" data-toggle-target="menu">
  <div class="flex flex-row-reverse items-center justify-between">
    <button aria-label="Close menu" class="-m-1 p-1" data-action="click->toggle#toggleMenu" data-toggle-target="closeButton">
      <svg viewBox="0 0 24 24" aria-hidden="true" class="h-6 w-6 text-zinc-500">
        <path d="m17.25 6.75-10.5 10.5M6.75 6.75l10.5 10.5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
      </svg>
    </button>
    <h2 class="text-sm font-medium text-zinc-600">Navigation</h2>
  </div>
  <nav class="mt-6">
    <ul class="-my-2 divide-y divide-zinc-100 text-base text-zinc-800">
      <% navigation_items.each do |item| %>
        <li><a href="<%= item[:href] %>" class="block py-2" data-action="click->toggle#closeMenu"><%= item[:name] %></a></li>
      <% end %>
    </ul>
  </nav>
</div>
